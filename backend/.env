# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
# Copy this to .env and fill in real values. NEVER commit .env to git.
# Add .env to your .gitignore immediately.
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay — get from dashboard.razorpay.com
# Use rzp_test_* keys during development, rzp_live_* in production
RAZORPAY_KEY_ID=rzp_test_SdqxHgGCDov9uo
RAZORPAY_KEY_SECRET=9OYfsKBmpYtj8bvGvHEgNKE9

# Admin/Scanner passwords — use strong random strings in production
# Generate with: openssl rand -base64 24
ADMIN_PASSWORD=HailHitler
SCANNER_PASSWORD=Dumbledore

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=b594-443f-a271-5de828982ecb

# OTP HMAC secret — generate with: openssl rand -hex 32
OTP_HMAC_SECRET=f5183f75e635d2717e4ea5cbd2d554e07390a89ec9a60cd581e7dcfe961e5d29

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://malhar.yoursite.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Supabase — get from supabase.com > project > settings > API
